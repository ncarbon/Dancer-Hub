{
  "expo": {
    "name": "Dancer Hub",
    "slug": "dancer-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dancerhub",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dancerhub.app",
      "icon": "./ios/DancerHub/Images.xcassets/AppIcon.appiconset/AppIcon-1024.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-foreground.png",
        "backgroundImage": "./assets/icons/adaptive-background.png"
      },
      "package": "com.dancerhub.app"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-audio",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dancer Hub to access your photo library to attach videos to routines."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a91a0ca-5cdc-4ce8-ae71-760f16776f8b"
      }
    }
  }
}
